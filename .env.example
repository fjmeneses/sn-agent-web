# Example configuration file for SecondNatureAgent Agent Backend
# Copy this to .env and replace with your actual values

# ==============================================================================
# Azure AI Services / Speech Configuration
# ==============================================================================
# Resource ID and endpoint for the Azure AI Services account.
# Authentication uses Microsoft Entra ID through DefaultAzureCredential.
AZURE_AI_SERVICES_RESOURCE_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/your-rg/providers/Microsoft.CognitiveServices/accounts/your-ai-services-account
AZURE_SPEECH_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure region (e.g., "eastus", "westus2", "southeastasia")
AZURE_SPEECH_REGION=your-ai-services-region

# ==============================================================================
# Azure OpenAI Configuration
# ==============================================================================
# Azure OpenAI endpoint on the Azure AI Services account
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/

# Azure OpenAI deployment name
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ==============================================================================
# Azure Text-to-Speech Configuration
# ==============================================================================
# Voice to use for TTS (default: en-US-AndrewNeural)
# See: https://learn.microsoft.com/en-us/azure/ai-services/speech-service/language-support
AZURE_TTS_VOICE=en-US-AndrewNeural

# ==============================================================================
# Agent Mode Configuration
# ==============================================================================
# Set to "true" for unattended mode (auto-speak responses)
# Set to "false" for interactive mode (wait for browser confirmation)
UNATTENDED=false
